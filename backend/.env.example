# Django — local manage.py defaults to dev; Gunicorn always uses portfolio.settings.prod
dev_DJANGO_DEBUG=True
prod_DJANGO_DEBUG=False
dev_ALLOWED_HOSTS=localhost,127.0.0.1
prod_ALLOWED_HOSTS=cankartal.com,www.cankartal.com

# Production database
prod_MYSQL_HOST=127.0.0.1
prod_MYSQL_PORT=3306
prod_MYSQL_USER=root
prod_MYSQL_PASSWORD=CHANGE_ME
prod_MYSQL_DATABASE=personal_portfolio
prod_SECRET_KEY=CHANGE_ME

# Development database (local only)
dev_MYSQL_HOST=127.0.0.1
dev_MYSQL_PORT=3306
dev_MYSQL_USER=root
dev_MYSQL_PASSWORD=CHANGE_ME
dev_MYSQL_DATABASE=personal_portfolio
dev_SECRET_KEY=CHANGE_ME

BIND_HOST=127.0.0.1
dev_port=47800
prod_port=59254

SESSION_COOKIE_NAME=admin_session
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=True

CORS_ORIGINS=https://cankartal.com,https://www.cankartal.com

POSTS_PER_PAGE=10
PROJECTS_PER_PAGE=12
MAX_CONTENT_LENGTH=104857600
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp
